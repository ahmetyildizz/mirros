generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique
  avatarUrl String?
  createdAt DateTime @default(now())

  hostedRooms  Room[]            @relation("HostedRooms")
  rooms        RoomParticipant[]
  answers      Answer[]
  guesses      Guess[]
  scores       Score[]
  insightsA    Insight[]         @relation("InsightUserA")
  insightsB    Insight[]         @relation("InsightUserB")
}

// ─── Room ─────────────────────────────────────────────────────

model Room {
  id         String     @id @default(cuid())
  code       String     @unique
  status     RoomStatus @default(WAITING)
  hostId     String
  maxPlayers Int        @default(8)
  gameMode   GameMode   @default(SOCIAL)
  ageGroup   AgeGroup?
  createdAt  DateTime   @default(now())

  host         User              @relation("HostedRooms", fields: [hostId], references: [id])
  participants RoomParticipant[]
  games        Game[]
}

model RoomParticipant {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

// ─── Game ─────────────────────────────────────────────────────

model Game {
  id          String     @id @default(cuid())
  roomId      String
  totalRounds Int        @default(5)
  status      GameStatus @default(ACTIVE)
  startedAt   DateTime   @default(now())
  finishedAt  DateTime?

  room     Room      @relation(fields: [roomId], references: [id])
  rounds   Round[]
  scores   Score[]
  insights Insight[]
}

model Round {
  id         String      @id @default(cuid())
  gameId     String
  number     Int
  questionId String
  answererId String?     // null for quiz mode
  status     RoundStatus @default(ANSWERING)

  game     Game     @relation(fields: [gameId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
  answers  Answer[]
  guesses  Guess[]
  scores   Score[]
}

model Answer {
  id          String   @id @default(cuid())
  roundId     String
  userId      String
  content     String
  submittedAt DateTime @default(now())

  round Round @relation(fields: [roundId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([roundId, userId])
}

model Guess {
  id          String   @id @default(cuid())
  roundId     String
  userId      String
  content     String
  submittedAt DateTime @default(now())

  round Round @relation(fields: [roundId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([roundId, userId])
}

model Score {
  id         String     @id @default(cuid())
  roundId    String
  gameId     String
  guesserId  String
  matchLevel MatchLevel
  points     Int
  createdAt  DateTime   @default(now())

  round   Round @relation(fields: [roundId], references: [id])
  game    Game  @relation(fields: [gameId], references: [id])
  guesser User  @relation(fields: [guesserId], references: [id])

  @@unique([roundId, guesserId])
}

model Question {
  id         String     @id @default(cuid())
  text       String
  category   String
  difficulty Difficulty @default(EASY)
  language   String     @default("tr")
  isActive   Boolean    @default(true)
  gameMode   GameMode   @default(SOCIAL)
  ageGroup   AgeGroup?
  options    Json?      // string[] — multiple choice options
  correct    String?    // correct answer for quiz mode

  rounds Round[]
}

model Insight {
  id         String   @id @default(cuid())
  gameId     String
  userAId    String
  userBId    String
  text       String
  patternKey String
  createdAt  DateTime @default(now())

  game  Game @relation(fields: [gameId], references: [id])
  userA User @relation("InsightUserA", fields: [userAId], references: [id])
  userB User @relation("InsightUserB", fields: [userBId], references: [id])
}

// ─── Enums ────────────────────────────────────────────────────

enum RoomStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum GameStatus {
  ACTIVE
  FINISHED
}

enum RoundStatus {
  ANSWERING
  GUESSING
  SCORED
}

enum MatchLevel {
  EXACT
  CLOSE
  WRONG
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum GameMode {
  SOCIAL
  QUIZ
}

enum AgeGroup {
  CHILD
  ADULT
  WISE
}
